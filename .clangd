CompileFlags:
  # clangd needs Clang-built PCMs (.pcm), not GCC gcm.cache (.gcm).
  # Run once: cmake --preset clang-debug && cmake --build --preset clang-debug
  CompilationDatabase: build/clang-debug
  Remove:
    # Warnings stay in compile_commands.json for ninja builds; clangd skips them.
    - -W*
    - -pedantic-errors
    - -fanalyzer
    - -fdiagnostics-color
    - -fcolor-diagnostics
    - -fdiagnostics-urls=*
    - -fdiagnostics-parseable-fixits
    - -fdiagnostics-generate-patch
    - -fdiagnostics-show-option
    # GCC-only module scanner flags (ignored for clang CDB anyway)
    - -fmodules-ts
    - -fmodule-mapper=*
    - -fdeps-format=*

Diagnostics:
  UnusedIncludes: None

---
If:
  PathMatch: ".*\\.cppm$"
CompileFlags:
  Add: [-x, c++-module]
