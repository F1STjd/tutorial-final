{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "gcc-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "D:/msys2/mingw64/bin/g++.exe",
        "CMAKE_CXX_FLAGS_INIT": "-O0 -g"
      }
    },
    {
      "name": "release-common",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_INIT": "-O3 -DNDEBUG -march=native -ffunction-sections -fdata-sections -fvisibility=hidden -funroll-loops",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "-Wl,--gc-sections -Wl,-O3",
        "CMAKE_SHARED_LINKER_FLAGS_INIT": "-Wl,--gc-sections -Wl,-O3"
      }
    },
    {
      "name": "gcc-release",
      "inherits": ["gcc-debug", "release-common"],
      "binaryDir": "${sourceDir}/build/gcc-release",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_INIT": "-O3 -DNDEBUG -march=native -ffunction-sections -fdata-sections -fvisibility=hidden -funroll-loops -fno-semantic-interposition -ftree-vectorize -fpredictive-commoning -fipa-pta",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "-Wl,--gc-sections -Wl,-O3",
        "CMAKE_SHARED_LINKER_FLAGS_INIT": "-Wl,--gc-sections -Wl,-O3"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "Clang Debug (clangd / IDE)",
      "inherits": "gcc-debug",
      "binaryDir": "${sourceDir}/build/clang-debug",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "D:/msys2/mingw64/bin/clang++.exe"
      }
    },
    {
      "name": "clang-release",
      "displayName": "Clang Release",
      "inherits": ["clang-debug", "release-common"],
      "binaryDir": "${sourceDir}/build/clang-release",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_INIT": "-O3 -DNDEBUG -march=native -ffunction-sections -fdata-sections -fvisibility=hidden -funroll-loops -flto=thin",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "-flto=thin -fuse-ld=lld -Wl,--gc-sections -Wl,-O3",
        "CMAKE_SHARED_LINKER_FLAGS_INIT": "-flto=thin -fuse-ld=lld -Wl,--gc-sections -Wl,-O3"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release"
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug",
      "nativeToolOptions": ["--quiet"]
    },
    {
      "name": "clang-release",
      "configurePreset": "clang-release",
      "nativeToolOptions": ["--quiet"]
    }
  ]
}
