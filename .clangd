CompileFlags:
  # clangd needs Clang-built PCMs (.pcm), not GCC gcm.cache (.gcm).
  # Run once: cmake --preset clang-debug && cmake --build --preset clang-debug
  CompilationDatabase: build/clang-debug
  Remove:
    - -fanalyzer
    - -fdiagnostics-color
    - -fdiagnostics-urls=*
    - -fdiagnostics-parseable-fixits
    - -fdiagnostics-generate-patch
    - -Wno-error=analyzer-*
    - -Wabi
    - -Wsuggest-attribute=*
    - -Wnoexcept
    - -Wredundant-tags
    - -Wfatal-errors
    - -Wnrvo
    - -Wtrampolines
    - -Wunsafe-loop-optimizations
    - -Wuseless-cast
    - -Wlogical-op
    - -Wsuggest-final-types
    - -Wsuggest-final-methods
    - -Wduplicated-branches
    - -Wduplicated-cond
    - -Walloc-zero
    - -Warith-conversion
    # GCC-only module scanner flags (ignored for clang CDB anyway)
    - -fmodules-ts
    - -fmodule-mapper=*
    - -fdeps-format=*
    - -Werror

Diagnostics:
  UnusedIncludes: None

---
If:
  PathMatch: ".*\\.cppm$"
CompileFlags:
  Add: [-x, c++-module]
